# Optional. Only needed for pm-sim run-agent --policy llm.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional. Enables model-backed semantic equivalence checks for action grading.
# Leave unset or set to deterministic for fully offline/reproducible runs.
PM_SIM_SEMANTIC_MATCHER=llm
PM_SIM_SEMANTIC_MODEL=gpt-4.1-mini
