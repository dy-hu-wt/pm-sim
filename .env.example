# Optional. Only needed for pm-sim run-agent --policy llm.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional. Action grading uses deterministic semantic checks by default.
# Set to llm only when you explicitly want model-backed phrasing equivalence.
PM_SIM_SEMANTIC_MATCHER=deterministic
PM_SIM_SEMANTIC_MODEL=gpt-4.1-mini
