# Required for full scoring and for pm-sim run-agent --policy llm.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional. Action-derived communication scoring uses concept matching.
# PM_SIM_CONCEPT_MODE=llm   -> LLM-backed, cached, fail-closed (default)
# PM_SIM_CONCEPT_MODE=local -> deterministic local matcher for reproducible no-key review
PM_SIM_CONCEPT_MODE=llm

# Optional when PM_SIM_CONCEPT_MODE=llm.
# Defaults to PM_SIM_CONCEPT_MODEL, then OPENAI_MODEL, then the built-in matcher model.
PM_SIM_CONCEPT_MODEL=gpt-4.1-mini

# Optional. Coworker replies use bounded LLM selection by default.
# Set deterministic for fully local/offline replay.
PM_SIM_COWORKER_MODE=llm
PM_SIM_COWORKER_MODEL=gpt-4.1-mini
