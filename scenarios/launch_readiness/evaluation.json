  "state_evidence_rules": [
    {
      "evidence_key": "blocker_discovered",
      "note": "Luigi has surfaced the stale repo-sync risk.",
      "when": [
        {
          "coworker_state": {
            "person_id": "luigi",
            "key": "risk_surfaced",
            "equals": true
          }
        }
      ],
      "created_at": {
        "coworker_state": {
          "person_id": "luigi",
          "key": "risk_surfaced"
        }
      }
    },
    {
      "evidence_key": "stakeholder_alignment",
      "note": "Daisy has shared Nimbus's reliability preference.",
      "when": [
        {
          "coworker_state": {
            "person_id": "daisy",
            "key": "reliability_preference_shared",
            "equals": true
          }
        }
      ],
      "created_at": {
        "coworker_state": {
          "person_id": "daisy",
          "key": "reliability_preference_shared"
