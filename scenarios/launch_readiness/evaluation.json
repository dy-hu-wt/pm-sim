              "signal_groups_all": [
                [
                  "csv",
                  "export"
                ],
                [
                  "one-time",
                  "one time",
                  "for the review",
                  "security review"
                ]
              ]
            },
            {
              "id": "self_serve_followup",
              "description": "Full self-serve export is deferred as follow-up after launch.",
              "signals_any": [
                "follow-up",
                "follow up",
                "self-serve",
                "self serve",
                "later",
                "after launch",
                "after nimbus launch"
              ]
            }
          ]
        }
      },
      "state": {
        "person_id": "daisy",
        "key": "koopa_update_received",
        "value": true
      },
      "evidence": {
        "key": "koopa_update_sent",
        "note": "Daisy has received a scoped Koopa update: one-time CSV for review, self-serve export as follow-up."
      },
      "effects": [
        {
          "type": "update_task",
          "task_id": "task_koopa_status_update",
          "status": "in_progress"
        },
        {
          "type": "update_project",
          "project_id": "project_audit_log_export",
          "status": "active",
          "risk_level": "low",
          "audit_export_status": "customer_update_ready"
        }
      ]
    },
