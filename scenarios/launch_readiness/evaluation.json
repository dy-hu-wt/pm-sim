  "task_gate_rules": [
    {
      "task_id": "task_repo_sync",
      "statuses": [
        "complete",
        "completed",
        "done",
        "resolved"
      ],
      "requires": [
        {
          "blocker_status": {
            "id": "blocker_repo_sync_stale",
            "is": "resolved"
          }
        }
      ],
      "error": "task_repo_sync cannot be marked complete while blocker_repo_sync_stale is unresolved."
    },
    {
      "task_id": "task_draft_mode_docs",
      "statuses": [
        "complete",
        "completed",
        "done",
        "resolved"
      ],
      "requires": [
        {
          "fact_discovered": "fact_draft_mode_scope_confirmed"
        },
        {
          "blocker_status": {
            "id": "blocker_scope_unclear",
            "is": "resolved"
          }
        },
        {
          "any": [
            {
              "project_decision": {
                "in": [
                  "draft_mode_selected",
                  "draft_mode_approved"
                ]
              }
            },
            {
              "fact_discovered": "fact_draft_mode_approved"
            }
          ]
        }
      ],
      "error": "task_draft_mode_docs cannot be marked complete without draft-mode scope confirmation, resolved scope blocker, draft-mode approval or selection."
    },
    {
      "task_id": "task_customer_talk_track",
      "statuses": [
        "complete",
        "completed",
        "done",
        "resolved"
      ],
      "requires": [
        {
          "any": [
            {
              "fact_discovered": "fact_nimbus_values_reliability"
            },
            {
              "evidence_exists": "stakeholder_alignment"
            }
          ]
        },
        {
          "coworker_state": {
            "person_id": "daisy",
            "key": "customer_message_ready",
            "equals": true
          }
        },
        {
          "any": [
            {
              "project_decision": {
                "exists": true
              }
            },
            {
              "fact_discovered": "fact_draft_mode_approved"
            }
          ]
        }
      ],
      "error": "task_customer_talk_track cannot be marked complete without Daisy alignment, customer-ready Daisy email, launch mode decision."
    },
    {
      "task_id": "task_launch_decision",
      "statuses": [
        "complete",
        "completed",
        "done",
        "resolved"
      ],
      "requires": [
        {
          "any": [
            {
              "fact_discovered": "fact_draft_mode_approved"
            },
            {
              "evidence_exists": "draft_mode_approved"
            }
          ]
        }
      ],
      "error": "task_launch_decision cannot be marked complete without Toad approval."
    },
    {
      "task_id": "task_audit_export_scope",
      "statuses": [
        "complete",
        "completed",
        "done",
        "resolved"
      ],
      "requires": [
        {
          "fact_discovered": "fact_audit_log_one_time_export_feasible"
        },
        {
          "fact_discovered": "fact_audit_export_scope_confirmed"
        },
        {
          "blocker_status": {
            "id": "blocker_audit_export_scope_unclear",
            "is": "resolved"
          }
        }
      ],
      "error": "task_audit_export_scope cannot be marked complete without feasible one-time CSV scope and resolved scope blocker."
    },
    {
      "task_id": "task_koopa_status_update",
      "statuses": [
        "complete",
        "completed",
        "done",
        "resolved"
      ],
      "requires": [
        {
          "coworker_state": {
            "person_id": "daisy",
            "key": "koopa_update_received",
            "equals": true
          }
        }
      ],
      "error": "task_koopa_status_update cannot be marked complete until Daisy receives the scoped Koopa update."
    }
  ],
  "outcome_rules": [
    {
      "id": "risky_auto_commenting",
      "when": [
        {
          "project_id": "project_pr_review_agent"
        },
        {
          "project_decision": {
            "in": [
              "auto_commenting_approved",
              "auto_commenting_selected",
              "auto_commenting_committed"
            ]
          }
        },
        {
          "blocker_status": {
            "id": "blocker_repo_sync_stale",
            "is": "unresolved"
          }
        }
      ],
      "result": {
