{
  "grading_rules": [
    {
      "id": "customer_message_ready",
      "template": "grounded_communication",
      "priority": 90,
      "requires": [
        {
          "fact_discovered": "fact_repo_sync_stale"
        },
        {
          "fact_discovered": "fact_nimbus_values_reliability"
        },
        {
          "any": [
            {
              "fact_discovered": "fact_draft_mode_approved"
            },
            {
              "project_decision": {
                "project_id": "project_pr_review_agent",
                "equals": "draft_mode_approved"
              }
            }
          ]
        }
      ],
      "action": {
        "type": "send_email",
        "recipient_id": "daisy",
        "semantic_match": {
          "required": [
            {
              "id": "repo_sync_risk",
              "description": "Repo sync or webhook ordering can make the agent review a stale or older commit.",
              "signal_groups_all": [
                [
                  "repo sync",
                  "repo-sync",
                  "webhook",
                  "stale",
                  "older commit",
                  "older diff"
                ],
                [
                  "risk",
                  "stale",
                  "older commit",
                  "older diff",
                  "commit"
                ]
              ]
            },
            {
              "id": "draft_mode",
              "description": "Friday launch mode is draft mode or queued draft suggestions.",
              "signals_any": [
                "draft mode",
                "draft-mode",
                "draft suggestions",
                "queue draft",
                "queues draft",
                "queued draft"
              ]
            },
            {
              "id": "nimbus_beta",
              "description": "The message is about the Nimbus Friday beta or pilot.",
              "signals_any": [
                "nimbus",
                "friday beta",
                "nimbus beta",
                "friday pilot",
                "pilot"
              ]
            },
            {
              "id": "human_approval",
              "description": "A human or reviewer must approve before anything is posted.",
              "signals_any": [
                "human approval",
                "approval before posting",
                "approve before posting",
                "review before posting",
                "reviewer approves",
                "human approves",
                "human review",
                "human-in-the-loop",
                "human in the loop",
                "before posting"
              ],
              "signal_groups_all": [
                [
                  "human",
                  "reviewer"
                ],
                [
                  "approve",
                  "approval",
                  "review"
                ],
                [
                  "posted",
                  "posting",
                  "post",
                  "comments",
                  "suggestions"
                ]
              ]
            }
          ]
        }
      },
      "state": {
        "person_id": "daisy",
        "key": "customer_message_ready",
        "value": true
      },
      "evidence": {
        "key": "customer_message_ready",
        "note": "Daisy has received grounded customer-ready Nimbus beta wording."
      }
    },
    {
      "id": "security_question_answered",
      "template": "grounded_communication",
      "priority": 80,
      "requires": [
        {
          "message_exists": {
            "sender_id": "daisy",
            "recipient_id": "agent",
            "terms_any": [
              "security",
              "source code",
              "private repo"
            ]
          }
        },
        {
          "coworker_state": {
            "person_id": "luigi",
            "key": "security_doc_shared",
            "equals": true
          }
        }
      ],
      "action": {
        "type": "send_email",
        "recipient_id": "daisy",
        "semantic_match": {
          "required": [
            {
              "id": "nimbus_beta",
              "description": "The message is about the Nimbus Friday beta or pilot.",
              "signals_any": [
                "nimbus",
                "friday beta",
                "nimbus beta",
                "friday pilot",
                "pilot"
              ]
            },
            {
              "id": "private_repo_security",
              "description": "The message addresses private repo source-code security handling.",
              "signals_any": [
                "private repo",
                "private repos",
                "source code",
                "raw source",
                "private-repo security",
                "security wording"
              ]
            },
            {
              "id": "transient_source_processing",
              "description": "Private repo source is processed transiently and raw source is not retained long term.",
              "signal_groups_all": [
                [
                  "transient",
                  "transiently",
                  "not stored",
                  "not retained",
                  "no long-term",
                  "not store"
                ],
                [
                  "source",
                  "source code",
                  "raw source",
                  "private repo",
                  "private-repo"
                ]
              ]
            },
            {
              "id": "beta_audit_retention",
              "description": "Generated suggestions or metadata are retained for the beta audit window.",
              "signal_groups_all": [
                [
                  "metadata",
                  "draft suggestions",
                  "generated suggestions",
                  "audit"
                ],
                [
                  "30 days",
                  "thirty days",
                  "beta audit",
                  "audit window",
                  "retained"
                ]
              ]
            }
          ]
        }
      },
      "state": {
        "person_id": "daisy",
        "key": "security_answer_received",
        "value": true
      },
      "evidence": {
        "key": "security_question_answered",
        "note": "Daisy has received a doc-backed answer on private repo source handling and beta retention limits."
      }
    },
    {
      "id": "koopa_update_sent",
      "template": "grounded_communication",
      "priority": 70,
      "requires": [
        {
          "fact_discovered": "fact_audit_log_one_time_export_feasible"
        },
        {
          "any": [
            {
              "fact_discovered": "fact_audit_export_scope_confirmed"
            },
            {
              "project_decision": {
                "project_id": "project_audit_log_export",
                "equals": "one_time_csv_for_review"
              }
            }
          ]
        }
      ],
      "action": {
        "type": "send_email",
        "recipient_id": "daisy",
        "semantic_match": {
          "required": [
            {
              "id": "koopa_audit",
              "description": "The message addresses Koopa audit-log or security-review needs.",
