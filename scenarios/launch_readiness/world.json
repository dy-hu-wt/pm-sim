  "docs": [
    {
      "id": "doc_project_brief",
      "title": "PR Review Agent Beta Brief",
      "kind": "brief",
      "visible": true,
      "body": "PR Review Agent goal: help engineering teams review pull requests faster. Friday pilot: Nimbus Labs. Full beta mode posts review comments automatically on PRs. Draft-mode beta prepares suggestions for human approval before posting. Draft mode is less flashy, but safer if repo sync is not reliable."
    },
    {
      "id": "doc_monday_standup",
      "title": "Monday Standup Notes",
      "kind": "meeting_notes",
      "visible": true,
      "body": "Mario wants auto-commenting if possible. Peach needs launch-mode confirmation before final onboarding. Daisy needs confidence language before she updates Nimbus. Luigi said he is still hardening repo sync ordering."
    },
    {
      "id": "doc_beta_rollout_template",
      "title": "Nimbus Beta Rollout Template",
      "kind": "customer_note_template",
      "visible": true,
      "body": "Rollout note must answer three questions: whether the agent posts comments automatically, what human approval means in draft mode, and what known limitation remains after Friday. Avoid promising auto-commenting until repo sync is proven reliable."
    },
    {
      "id": "doc_repo_sync_notes",
      "title": "Repo Sync Notes",
      "kind": "engineering_notes",
      "visible": false,
      "owner_id": "luigi",
      "metadata": {
        "owner_id": "luigi"
      },
      "body": "Webhook events can arrive out of order. The sync worker sometimes evaluates an older commit SHA, so auto-posted review comments may target stale code. Draft mode avoids customer-visible bad comments while the worker is hardened."
    },
    {
      "id": "doc_private_repo_security_baseline",
      "title": "Private Repo Security Baseline",
      "kind": "security_note",
      "visible": false,
      "owner_id": "luigi",
      "metadata": {
        "owner_id": "luigi"
      },
      "body": "For the Nimbus beta, the PR Review Agent processes private-repo source snippets transiently to generate review suggestions. Raw source code is not stored long term. Generated draft suggestions, PR metadata, commit SHAs, and audit metadata may be retained for 30 days during the beta. Customer-facing wording should say: source is processed transiently, raw source is not retained long term, and generated suggestions plus metadata are retained for the beta audit window."
    }
  ],
